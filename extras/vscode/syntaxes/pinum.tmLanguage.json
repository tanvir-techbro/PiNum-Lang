{
  "name": "PiNum",
  "scopeName": "source.pn",
  "patterns": [
    {
      "name": "comment.line.hashtag.pn",
      "match": "#.*$"
    },
    {
      "name": "keyword.control.directive.pn",
      "match": "@\\w+"
    },
    {
      "name": "keyword.control.pn",
      "match": "\\b(if|else|print|read|return|import|include|while|for)\\b"
    },
    {
      "name": "storage.type.pn",
      "match": "\\b(int|float|double|char|string|bool|long|short|signed|unsigned|vec)\\b"
    },
    {
      "name": "constant.language.pn",
      "match": "\\b(true|false|stdlib|math|engine)\\b"
    },
    {
      "name": "constant.numeric.pn",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    {
      "name": "string.quoted.double.pn",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.pn",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "keyword.operator.pn",
      "match": "[+=\\-\\*/%&^|!<>?~]"
    }
  ]
}
